# Server configuration
PORT=8080

# Database Configuration
# Replace with your local or remote PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexai

# Clerk Authentication (Backend & Frontend)
# Retrieve these credentials from your Clerk dashboard (https://clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Frontend Clerk Configuration (Vite requires VITE_ prefix)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional Clerk Proxy (needed if deploying with a proxy setup in production)
# VITE_CLERK_PROXY_URL=http://localhost:8080/api/__clerk
